---
import Layout from '../../layouts/Layout.astro';
import { db, Reflection } from 'astro:db';

let message = "";

if (Astro.request.method === 'POST') {
  try {
    const data = await Astro.request.formData();
    const userId = data.get('userId');
    const selfEvaluation = Number(data.get('selfEvaluation'));
    const changeRequest = data.get('changeRequest') === 'on';

    if (typeof userId === 'string') {
      await db.insert(Reflection).values({
        userId,
        targetMonth: '2026-04',
        selfEvaluation,
        changeRequest
      });
      message = "振り返りを記録しました！";
    }
  } catch (error) {
    message = "エラーが発生しました。";
    console.error(error);
  }
}
---

<Layout title="振り返り | セルフプランニング支援アプリ">
  <div class="max-w-3xl mx-auto space-y-8">
    
    <div class="bg-white p-6 md:p-8 rounded-2xl shadow-lg border-2 border-blue-100">
      <h2 class="text-2xl font-extrabold text-blue-800 mb-6">📊 今月の活動データ（2026年4月）</h2>
      
      <div class="grid grid-cols-2 gap-6">
        <div class="bg-blue-50 p-6 rounded-2xl text-center border-2 border-blue-100">
          <div class="text-gray-600 font-bold mb-2">出勤日数</div>
          <div class="text-5xl font-extrabold text-blue-700">18 <span class="text-2xl text-blue-500">日</span></div>
        </div>
        <div class="bg-green-50 p-6 rounded-2xl text-center border-2 border-green-100">
          <div class="text-gray-600 font-bold mb-2">作業時間合計</div>
          <div class="text-5xl font-extrabold text-green-700">45 <span class="text-2xl text-green-500">時間</span></div>
        </div>
      </div>
      <p class="text-gray-500 text-sm mt-4 text-center">※モックのため固定データを表示しています。</p>
    </div>

    <div class="bg-white p-6 md:p-8 rounded-2xl shadow-lg border-2 border-blue-100">
      <h2 class="text-2xl font-extrabold text-blue-800 mb-6">🎯 今月の目標に対する振り返り</h2>

      {message && (
        <div class="mb-6 p-4 bg-green-100 text-green-800 text-xl font-bold rounded-xl text-center border-2 border-green-400">
          {message}
        </div>
      )}

      <form method="POST" class="space-y-8">
        {/* 利用者ID（簡易的） */}
        <div>
          <label for="userId" class="block text-xl font-bold text-gray-800 mb-3">あなたのID</label>
          <input 
            type="text" 
            id="userId" 
            name="userId" 
            required
            placeholder="例: user001"
            class="w-full text-xl p-4 border-4 border-gray-300 rounded-xl focus:border-blue-500 outline-none"
          >
        </div>

        {/* 5段階評価 */}
        <div>
          <label class="block text-xl font-bold text-gray-800 mb-3">今月の目標はどれくらい達成できましたか？</label>
          <div class="flex justify-between gap-2">
            {[1, 2, 3, 4, 5].map((score) => (
              <label class="flex-1 cursor-pointer">
                <input type="radio" name="selfEvaluation" value={score} class="peer sr-only" required>
                <div class="text-center py-4 bg-gray-100 rounded-xl border-4 border-gray-200 peer-checked:bg-blue-600 peer-checked:border-blue-800 peer-checked:text-white font-bold text-xl transition-all hover:bg-gray-200">
                  {score}
                </div>
              </label>
            ))}
          </div>
          <div class="flex justify-between text-sm text-gray-500 font-bold mt-2 px-2">
            <span>まったく</span>
            <span>とても</span>
          </div>
        </div>

        {/* 変更希望 */}
        <div class="bg-yellow-50 p-6 rounded-xl border-4 border-yellow-200">
          <label class="flex items-center gap-4 cursor-pointer">
            <input type="checkbox" name="changeRequest" class="w-8 h-8 text-blue-600 border-gray-300 rounded focus:ring-blue-500">
            <span class="text-xl font-bold text-gray-800">来月から作業内容や時間を変更したいですか？</span>
          </label>
          <p class="text-gray-600 mt-2 ml-12">※チェックを入れると、職員から相談のお声がけをします。</p>
        </div>

        {/* 送信ボタン */}
        <button 
          type="submit" 
          class="w-full text-2xl font-extrabold text-white bg-blue-600 py-5 rounded-xl shadow-xl hover:bg-blue-700 active:scale-95 transition-transform Submit Button (送信)"
        >
          📤 振り返りを送信する
        </button>
      </form>
    </div>
  </div>
</Layout>
