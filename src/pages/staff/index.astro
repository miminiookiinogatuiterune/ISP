---
import Layout from '../../layouts/Layout.astro';
import { db, DailyReport, User, eq } from 'astro:db';

// データの取得 (UserテーブルをJoinして名前も取得できるようにする)
const reportsRaw = await db.select().from(DailyReport);
const users = await db.select().from(User);

// 簡易的なJoin
const reports = reportsRaw.map(report => {
  const user = users.find(u => u.id === report.userId);
  return {
    ...report,
    userName: user ? user.name : '不明なユーザー'
  };
}).sort((a, b) => b.createdAt.getTime() - a.createdAt.getTime());

if (Astro.request.method === 'POST') {
  try {
    const data = await Astro.request.formData();
    const id = Number(data.get('id'));
    const staffNote = data.get('staffNote');

    if (id && typeof staffNote === 'string') {
      // 本来は update()
    }
  } catch (error) {
    console.error(error);
  }
}
---

<Layout title="職員管理画面 | セルフプランニング支援アプリ">
  <div class="space-y-6">
    <div class="flex justify-between items-end mb-2 px-2">
      <div>
        <h2 class="text-3xl font-semibold text-apple-ink tracking-tight mb-1">利用者日報一覧</h2>
        <p class="text-sm text-apple-secondary">直近の入力データ</p>
      </div>
      <div class="flex gap-3">
        <a href="/staff/users/new" class="bg-apple-ink text-white px-5 py-2.5 rounded-full text-sm font-semibold hover:bg-black transition-colors Add User Button (新規登録)">
          ＋ 新規利用者登録
        </a>
      </div>
    </div>

    <div class="bg-white rounded-[24px] shadow-[0_4px_24px_rgba(0,0,0,0.04)] border border-apple-border-soft overflow-hidden">
      <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse text-sm">
          <thead>
            <tr class="border-b border-apple-border-soft bg-apple-gray/50 text-apple-secondary">
              <th class="p-4 font-semibold whitespace-nowrap">日付</th>
              <th class="p-4 font-semibold whitespace-nowrap">氏名 / ID</th>
              <th class="p-4 font-semibold whitespace-nowrap">作業</th>
              <th class="p-4 font-semibold whitespace-nowrap text-center">体調</th>
              <th class="p-4 font-semibold w-1/4">コメント</th>
              <th class="p-4 font-semibold w-1/4">特記事項</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-apple-border-soft">
            {reports.map((report) => (
              <tr class="hover:bg-gray-50/50 transition-colors">
                <td class="p-4 text-apple-secondary">
                  {new Date(report.createdAt).toLocaleDateString('ja-JP')}
                </td>
                <td class="p-4">
                  <div class="font-semibold text-apple-ink">{report.userName}</div>
                  <div class="text-xs text-apple-secondary mt-0.5">{report.userId}</div>
                </td>
                <td class="p-4">
                  <span class="inline-flex items-center px-2.5 py-1 rounded-md text-xs font-medium bg-apple-gray text-apple-ink border border-apple-border-soft">
                    {report.taskType} <span class="ml-1.5 text-apple-secondary">{report.taskDuration}h</span>
                  </span>
                </td>
                <td class="p-4 text-center text-xl">
                  {report.healthStatus === 3 ? '😄' : report.healthStatus === 2 ? '😐' : '😷'}
                </td>
                <td class="p-4 text-apple-ink break-words">
                  {report.comment || <span class="text-apple-border-soft">-</span>}
                </td>
                <td class="p-4">
                  <form method="POST" class="flex gap-2">
                    <input type="hidden" name="id" value={report.id} />
                    <input 
                      type="text" 
                      name="staffNote" 
                      value={report.staffNote || ''} 
                      placeholder="追記..." 
                      class="flex-1 min-w-[120px] border border-apple-border-soft rounded-lg px-3 py-1.5 text-sm focus:border-apple-border-strong focus:outline-none transition-colors"
                    />
                    <button type="submit" class="bg-apple-gray text-apple-ink border border-apple-border-soft px-3 py-1.5 rounded-lg text-xs font-semibold hover:bg-gray-200 transition-colors Save Button (保存)">
                      保存
                    </button>
                  </form>
                </td>
              </tr>
            ))}

            {reports.length === 0 && (
              <tr>
                <td colspan="6" class="p-12 text-center text-apple-secondary">
                  日報データがありません。
                </td>
              </tr>
            )}
          </tbody>
        </table>
      </div>
    </div>
  </div>
</Layout>
