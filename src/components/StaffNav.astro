---
const { current } = Astro.props;
const tabs = [
  { id: 'daily', name: '日々の記録', href: '/staff' },
  { id: 'assessment', name: 'アセスメント / 計画', href: '/staff/assessment' },
  { id: 'users', name: '利用者・目標管理', href: '/staff/users' }
];
---
<nav class="flex space-x-2 bg-apple-gray p-1.5 rounded-xl mb-6 border border-apple-border-soft">
  {tabs.map(tab => (
    <a href={tab.href} class={`flex-1 text-center py-2.5 px-4 rounded-lg text-sm font-semibold transition-all ${current === tab.id ? 'bg-white text-apple-ink shadow-[0_2px_8px_rgba(0,0,0,0.06)]' : 'text-apple-secondary hover:text-apple-ink hover:bg-black/5'}`}>
      {tab.name}
    </a>
  ))}
</nav>
