---
import Layout from '../layouts/Layout.astro';
import { db, DailyReport, User, Reflection, eq } from 'astro:db';

let message = "";
const urlUserId = Astro.url.searchParams.get('userId');
let defaultUserId = urlUserId || "";
let userName = "";

// 今日の日付を取得 (例: 2026年4月24日（金）)
const today = new Date();
const todayStr = today.toLocaleDateString('ja-JP', { year: 'numeric', month: 'long', day: 'numeric', weekday: 'short' });

// 先月を計算（例: "2026-03"）
const lastMonthDate = new Date(today.getFullYear(), today.getMonth() - 1, 1);
const lastMonthStr = `${lastMonthDate.getFullYear()}-${String(lastMonthDate.getMonth() + 1).padStart(2, '0')}`;

// URLにuserIdがあれば名前を取得し、先月の振り返りが終わっているかチェック
if (defaultUserId) {
  const users = await db.select().from(User).where(eq(User.id, defaultUserId));
  if (users.length > 0) {
    userName = users[0].name;

    // 先月の振り返りチェック
    const userReflections = await db.select().from(Reflection).where(eq(Reflection.userId, defaultUserId));
    const hasReflectedLastMonth = userReflections.some(r => r.targetMonth === lastMonthStr);
    
    // もし先月の振り返りが未完了なら、振り返り画面へリダイレクト
    // （※ただしPOST送信時＝日報送信時はリダイレクトしない）
    if (!hasReflectedLastMonth && Astro.request.method !== 'POST') {
      return Astro.redirect(`/reflection?userId=${defaultUserId}`);
    }
  }
}

if (Astro.request.method === 'POST') {
  try {
    const data = await Astro.request.formData();
    const userId = data.get('userId');
    let taskType = data.get('taskType');
    const taskOtherDetail = data.get('taskOtherDetail');
    const startTime = data.get('startTime');
    const endTime = data.get('endTime');
    const healthStatus = Number(data.get('healthStatus'));
    const comment = data.get('comment');

    // 「その他」が選択されていて、詳細が入力されている場合は結合する
    if (taskType === 'その他' && typeof taskOtherDetail === 'string' && taskOtherDetail.trim() !== '') {
      taskType = `その他：${taskOtherDetail.slice(0, 20)}`;
    }

    if (typeof userId === 'string' && typeof taskType === 'string' && typeof startTime === 'string' && typeof endTime === 'string') {
      await db.insert(DailyReport).values({
        userId,
        taskType,
        startTime,
        endTime,
        healthStatus,
        comment: typeof comment === 'string' ? comment.slice(0, 20) : '',
      });
      message = "日報を送信しました。お疲れ様でした！";
    }
  } catch (error) {
    message = "エラーが発生しました。";
    console.error(error);
  }
}

// 5分刻みの時間リストを生成 (09:00 〜 18:00)
const timeOptions: string[] = [];
for (let h = 9; h <= 18; h++) {
  for (let m = 0; m < 60; m += 5) {
    if (h === 18 && m > 0) continue;
    const hour = h.toString().padStart(2, '0');
    const min = m.toString().padStart(2, '0');
    timeOptions.push(`${hour}:${min}`);
  }
}
---

<Layout title="日報入力 | セルフプランニング支援アプリ">
  <div class="max-w-xl mx-auto bg-white p-8 md:p-12 rounded-[24px] shadow-[0_4px_24px_rgba(0,0,0,0.04)] border border-apple-border-soft">
    <div class="text-center mb-10">
      <div class="text-sm font-semibold text-apple-secondary mb-2">{todayStr}</div>
      <h2 class="text-3xl font-semibold text-apple-ink tracking-tight mb-2">今日の日報</h2>
      {userName ? (
        <p class="text-apple-secondary text-lg">ようこそ、<span class="font-semibold text-apple-ink">{userName}</span> さん</p>
      ) : (
        <div class="p-6 mt-4 bg-red-50 text-red-700 font-semibold rounded-2xl border border-red-200">
          <p class="text-lg mb-2">⚠️ 直接のアクセスはできません</p>
          <p class="text-sm font-normal">施設から配布された「専用のQRコード」を読み込んでアクセスしてください。</p>
        </div>
      )}
    </div>
    
    {message && (
      <div class="mb-8 p-4 bg-gray-50 text-apple-ink font-medium rounded-xl border border-apple-border-soft text-center">
        {message}
      </div>
    )}

    {!message && userName && (
      <form method="POST" class="space-y-10" id="dailyReportForm">
        <input type="hidden" name="userId" value={defaultUserId} />

        {/* 2. 作業内容 */}
        <div>
          <label class="block text-sm font-semibold text-apple-secondary mb-3">2. どんな作業をしましたか？</label>
          <div class="grid grid-cols-2 gap-3 mb-3">
            {['アクセサリー制作', '梱包', '清掃', 'その他'].map((task) => (
              <label class="cursor-pointer relative">
                <input type="radio" name="taskType" value={task} class="peer sr-only task-radio" required>
                <div class="text-center py-4 bg-apple-gray text-apple-ink rounded-xl border border-transparent peer-checked:bg-apple-blue peer-checked:text-white transition-all hover:bg-gray-200 peer-checked:hover:bg-apple-blue font-medium text-sm md:text-base">
                  {task}
                </div>
              </label>
            ))}
          </div>
          {/* その他を選択した時の詳細入力欄（JSで表示切り替え） */}
          <div id="otherDetailWrapper" class="hidden">
            <input 
              type="text" 
              name="taskOtherDetail" 
              maxlength="20"
              placeholder="午前・午後など、自由に入力（20文字まで）"
              class="w-full p-4 bg-apple-gray border border-apple-border-soft rounded-xl focus:border-apple-border-strong focus:bg-white focus:outline-none transition-colors text-apple-ink font-medium text-sm"
            >
          </div>
        </div>

        {/* 3. 作業時間（出退勤） */}
        <div>
          <label class="block text-sm font-semibold text-apple-secondary mb-3">3. 今日の時間は？</label>
          <div class="flex items-center gap-4">
            <div class="flex-1">
              <label for="startTime" class="block text-xs font-semibold text-apple-secondary mb-1">出勤時間</label>
              <div class="relative">
                <select name="startTime" id="startTime" required class="w-full p-4 bg-apple-gray border border-apple-border-soft rounded-xl focus:border-apple-border-strong focus:bg-white focus:outline-none transition-colors text-apple-ink font-semibold text-lg appearance-none cursor-pointer">
                  <option value="" disabled selected>--:--</option>
                  {timeOptions.map(time => (
                    <option value={time}>{time}</option>
                  ))}
                </select>
                <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-4 text-apple-secondary">▼</div>
              </div>
            </div>
            <div class="text-apple-secondary font-semibold mt-4">〜</div>
            <div class="flex-1">
              <label for="endTime" class="block text-xs font-semibold text-apple-secondary mb-1">退勤時間</label>
              <div class="relative">
                <select name="endTime" id="endTime" required class="w-full p-4 bg-apple-gray border border-apple-border-soft rounded-xl focus:border-apple-border-strong focus:bg-white focus:outline-none transition-colors text-apple-ink font-semibold text-lg appearance-none cursor-pointer">
                  <option value="" disabled selected>--:--</option>
                  {timeOptions.map(time => (
                    <option value={time}>{time}</option>
                  ))}
                </select>
                <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-4 text-apple-secondary">▼</div>
              </div>
            </div>
          </div>
        </div>

        {/* 4. 体調 */}
        <div>
          <label class="block text-sm font-semibold text-apple-secondary mb-3">4. 今日の体調はどうですか？</label>
          <div class="flex gap-3">
            {[
              { value: 3, emoji: '😄', label: '元気' },
              { value: 2, emoji: '😐', label: 'ふつう' },
              { value: 1, emoji: '😷', label: 'よくない' }
            ].map((status) => (
              <label class="flex-1 cursor-pointer">
                <input type="radio" name="healthStatus" value={status.value} class="peer sr-only" required>
                <div class="flex flex-col items-center justify-center py-5 bg-apple-gray rounded-[20px] border border-transparent peer-checked:bg-white peer-checked:border-apple-ink transition-all hover:bg-gray-200 peer-checked:hover:bg-white shadow-[0_0_0_0_rgba(0,0,0,0)] peer-checked:shadow-[0_2px_8px_rgba(0,0,0,0.08)]">
                  <span class="text-4xl mb-2 grayscale opacity-80 peer-checked:grayscale-0 peer-checked:opacity-100 transition-all">{status.emoji}</span>
                  <span class="text-xs font-semibold text-apple-secondary peer-checked:text-apple-ink transition-colors">{status.label}</span>
                </div>
              </label>
            ))}
          </div>
        </div>

        {/* 5. 一言コメント */}
        <div>
          <label for="comment" class="block text-sm font-semibold text-apple-secondary mb-2">5. 今日やったことや感想（20文字まで）</label>
          <input 
            type="text" 
            id="comment" 
            name="comment" 
            maxlength="20"
            placeholder="短く感想を書いてください"
            class="w-full p-4 bg-apple-gray border border-apple-border-soft rounded-xl focus:border-apple-border-strong focus:bg-white focus:outline-none transition-colors text-apple-ink font-medium"
          >
        </div>

        {/* 送信ボタン */}
        <div class="pt-4">
          <button 
            type="submit" 
            class="w-full text-lg font-semibold text-white bg-apple-blue py-4 rounded-full shadow-[0_4px_14px_rgba(0,113,227,0.3)] hover:bg-apple-blue-hover active:scale-[0.98] transition-all Submit Button (送信)"
          >
            この内容で送信する
          </button>
        </div>
      </form>
    )}
  </div>

  <script>
    // 「その他」が選択された時に詳細入力欄を表示する処理
    const radios = document.querySelectorAll('.task-radio');
    const otherDetailWrapper = document.getElementById('otherDetailWrapper');

    radios.forEach(radio => {
      radio.addEventListener('change', (e) => {
        if ((e.target as HTMLInputElement).value === 'その他') {
          otherDetailWrapper?.classList.remove('hidden');
          const input = otherDetailWrapper?.querySelector('input');
          if (input) input.required = true;
        } else {
          otherDetailWrapper?.classList.add('hidden');
          const input = otherDetailWrapper?.querySelector('input');
          if (input) {
            input.required = false;
            input.value = '';
          }
        }
      });
    });
  </script>
</Layout>
