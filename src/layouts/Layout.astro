---
import '../styles/global.css';

interface Props {
	title?: string;
}

const { title = "セルフプランニング支援アプリ" } = Astro.props;
---
<!doctype html>
<html lang="ja">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body class="bg-gray-100 text-gray-900 font-sans min-h-screen flex flex-col">
		<header class="bg-blue-600 text-white p-4 shadow-md sticky top-0 z-10">
			<div class="container mx-auto flex justify-between items-center max-w-4xl">
				<h1 class="text-xl font-bold">福祉支援アプリ</h1>
				<nav class="space-x-4">
					<a href="/" class="hover:underline">日報入力</a>
					<a href="/staff" class="hover:underline">職員管理</a>
					<a href="/reflection" class="hover:underline">振り返り</a>
				</nav>
			</div>
		</header>
		<main class="flex-grow container mx-auto p-4 max-w-4xl">
			<slot />
		</main>
		<footer class="bg-gray-200 text-center p-4 text-sm text-gray-600">
			&copy; 2026 セルフプランニング支援プロジェクト
		</footer>
	</body>
</html>
