---
import Layout from '../layouts/Layout.astro';
import { db, DailyReport, User, eq } from 'astro:db';

let message = "";
const urlUserId = Astro.url.searchParams.get('userId');
let defaultUserId = urlUserId || "";
let userName = "";

// URLにuserIdがあれば名前を取得
if (defaultUserId) {
  const users = await db.select().from(User).where(eq(User.id, defaultUserId));
  if (users.length > 0) {
    userName = users[0].name;
  }
}

if (Astro.request.method === 'POST') {
  try {
    const data = await Astro.request.formData();
    const userId = data.get('userId');
    const taskType = data.get('taskType');
    const taskDuration = Number(data.get('taskDuration'));
    const healthStatus = Number(data.get('healthStatus'));
    const comment = data.get('comment');

    if (typeof userId === 'string' && typeof taskType === 'string') {
      await db.insert(DailyReport).values({
        userId,
        taskType,
        taskDuration,
        healthStatus,
        comment: typeof comment === 'string' ? comment.slice(0, 20) : '',
      });
      message = "日報を送信しました。お疲れ様でした！";
    }
  } catch (error) {
    message = "エラーが発生しました。";
    console.error(error);
  }
}
---

<Layout title="日報入力 | セルフプランニング支援アプリ">
  <div class="max-w-xl mx-auto bg-white p-8 md:p-12 rounded-[24px] shadow-[0_4px_24px_rgba(0,0,0,0.04)] border border-apple-border-soft">
    <div class="text-center mb-10">
      <h2 class="text-3xl font-semibold text-apple-ink tracking-tight mb-2">今日の日報</h2>
      {userName ? (
        <p class="text-apple-secondary text-lg">ようこそ、<span class="font-semibold text-apple-ink">{userName}</span> さん</p>
      ) : (
        <p class="text-apple-secondary text-lg">今日の記録を入力してください</p>
      )}
    </div>
    
    {message && (
      <div class="mb-8 p-4 bg-gray-50 text-apple-ink font-medium rounded-xl border border-apple-border-soft text-center">
        {message}
      </div>
    )}

    {!message && (
      <form method="POST" class="space-y-10">
        {/* 1. 利用者ID (URLパラメータがある場合は非表示で送信、ない場合は入力) */}
        {defaultUserId ? (
          <input type="hidden" name="userId" value={defaultUserId} />
        ) : (
          <div>
            <label for="userId" class="block text-sm font-semibold text-apple-secondary mb-2">1. あなたのID</label>
            <input 
              type="text" 
              id="userId" 
              name="userId" 
              required
              placeholder="user001"
              class="w-full p-4 bg-apple-gray border border-apple-border-soft rounded-xl focus:border-apple-border-strong focus:bg-white focus:outline-none transition-colors text-apple-ink font-medium"
            >
          </div>
        )}

        {/* 2. 作業内容 */}
        <div>
          <label class="block text-sm font-semibold text-apple-secondary mb-3">2. どんな作業をしましたか？</label>
          <div class="grid grid-cols-2 gap-3">
            {['アクセサリー制作', '梱包', '清掃', 'その他'].map((task) => (
              <label class="cursor-pointer relative">
                <input type="radio" name="taskType" value={task} class="peer sr-only" required>
                <div class="text-center py-4 bg-apple-gray text-apple-ink rounded-xl border border-transparent peer-checked:bg-apple-blue peer-checked:text-white transition-all hover:bg-gray-200 peer-checked:hover:bg-apple-blue font-medium text-sm md:text-base">
                  {task}
                </div>
              </label>
            ))}
          </div>
        </div>

        {/* 3. 作業時間 */}
        <div>
          <label class="block text-sm font-semibold text-apple-secondary mb-3">3. 何時間作業しましたか？</label>
          <div class="flex gap-3">
            {[1, 2, 3].map((time) => (
              <label class="flex-1 cursor-pointer">
                <input type="radio" name="taskDuration" value={time} class="peer sr-only" required>
                <div class="text-center py-4 bg-apple-gray text-apple-ink rounded-xl border border-transparent peer-checked:bg-apple-ink peer-checked:text-white transition-all hover:bg-gray-200 peer-checked:hover:bg-apple-ink font-semibold text-lg">
                  {time}h
                </div>
              </label>
            ))}
          </div>
        </div>

        {/* 4. 体調 */}
        <div>
          <label class="block text-sm font-semibold text-apple-secondary mb-3">4. 今日の体調はどうですか？</label>
          <div class="flex gap-3">
            {[
              { value: 3, emoji: '😄', label: '元気' },
              { value: 2, emoji: '😐', label: 'ふつう' },
              { value: 1, emoji: '😷', label: 'よくない' }
            ].map((status) => (
              <label class="flex-1 cursor-pointer">
                <input type="radio" name="healthStatus" value={status.value} class="peer sr-only" required>
                <div class="flex flex-col items-center justify-center py-5 bg-apple-gray rounded-[20px] border border-transparent peer-checked:bg-white peer-checked:border-apple-ink transition-all hover:bg-gray-200 peer-checked:hover:bg-white shadow-[0_0_0_0_rgba(0,0,0,0)] peer-checked:shadow-[0_2px_8px_rgba(0,0,0,0.08)]">
                  <span class="text-4xl mb-2 grayscale opacity-80 peer-checked:grayscale-0 peer-checked:opacity-100 transition-all">{status.emoji}</span>
                  <span class="text-xs font-semibold text-apple-secondary peer-checked:text-apple-ink transition-colors">{status.label}</span>
                </div>
              </label>
            ))}
          </div>
        </div>

        {/* 5. 一言コメント */}
        <div>
          <label for="comment" class="block text-sm font-semibold text-apple-secondary mb-2">5. 一言コメント（20文字まで）</label>
          <input 
            type="text" 
            id="comment" 
            name="comment" 
            maxlength="20"
            placeholder="短く感想を書いてください"
            class="w-full p-4 bg-apple-gray border border-apple-border-soft rounded-xl focus:border-apple-border-strong focus:bg-white focus:outline-none transition-colors text-apple-ink font-medium"
          >
        </div>

        {/* 送信ボタン */}
        <div class="pt-4">
          <button 
            type="submit" 
            class="w-full text-lg font-semibold text-white bg-apple-blue py-4 rounded-full shadow-[0_4px_14px_rgba(0,113,227,0.3)] hover:bg-apple-blue-hover active:scale-[0.98] transition-all Submit Button (送信)"
          >
            この内容で送信する
          </button>
        </div>
      </form>
    )}
  </div>
</Layout>
