---
import '@fontsource/inter/400.css';
import '@fontsource/inter/600.css';
import '@fontsource/inter/700.css';
import '../styles/global.css';

interface Props {
	title?: string;
}

const { title = "セルフプランニング支援アプリ" } = Astro.props;
---
<!doctype html>
<html lang="ja">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body class="bg-apple-gray text-apple-ink font-sans min-h-screen flex flex-col antialiased">
		<header class="bg-black/80 backdrop-blur-md text-white p-3 sticky top-0 z-50">
			<div class="container mx-auto flex justify-between items-center max-w-4xl text-sm">
				<a href="/" class="font-semibold text-white/90 hover:text-white transition-colors"> アプリ</a>
				<nav class="space-x-6">
					<a href="/" class="text-white/80 hover:text-white transition-colors">日報入力</a>
					<a href="/staff" class="text-white/80 hover:text-white transition-colors">職員管理</a>
					<a href="/reflection" class="text-white/80 hover:text-white transition-colors">振り返り</a>
				</nav>
			</div>
		</header>
		<main class="flex-grow container mx-auto px-4 py-12 max-w-4xl">
			<slot />
		</main>
		<footer class="bg-apple-gray text-center p-6 text-xs text-apple-secondary border-t border-apple-border-soft">
			&copy; 2026 セルフプランニング支援プロジェクト. All rights reserved.
		</footer>
	</body>
</html>
