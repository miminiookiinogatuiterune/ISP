---
import Layout from '../../layouts/Layout.astro';
import StaffNav from '../../components/StaffNav.astro';
import { db, DailyReport, User, eq } from 'astro:db';

// データの取得
const reportsRaw = await db.select().from(DailyReport);
const users = await db.select().from(User);

// 簡易的なJoin
const reports = reportsRaw.map(report => {
  const user = users.find(u => u.id === report.userId);
  return {
    ...report,
    userName: user ? user.name : '不明なユーザー'
  };
}).sort((a, b) => b.createdAt.getTime() - a.createdAt.getTime());

if (Astro.request.method === 'POST') {
  // ...
}
---

<Layout title="職員管理画面 | セルフプランニング支援アプリ">
  <div class="space-y-6 max-w-5xl mx-auto">
    
    <div class="mb-8">
      <h2 class="text-3xl font-semibold text-apple-ink tracking-tight mb-2">職員管理画面</h2>
      <StaffNav current="daily" />
    </div>

    <div class="flex justify-between items-end mb-2 px-2">
      <div>
        <h3 class="text-xl font-semibold text-apple-ink tracking-tight mb-1">利用者日報一覧</h3>
        <p class="text-sm text-apple-secondary">直近に入力された日報（App A のデータ）</p>
      </div>
    </div>

    <div class="bg-white rounded-[24px] shadow-[0_4px_24px_rgba(0,0,0,0.04)] border border-apple-border-soft overflow-hidden">
      <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse text-sm">
          <thead>
            <tr class="border-b border-apple-border-soft bg-apple-gray/50 text-apple-secondary">
              <th class="p-4 font-semibold whitespace-nowrap">日付</th>
              <th class="p-4 font-semibold whitespace-nowrap">氏名 / ID</th>
              <th class="p-4 font-semibold whitespace-nowrap">作業</th>
              <th class="p-4 font-semibold whitespace-nowrap text-center">体調</th>
              <th class="p-4 font-semibold w-1/4">コメント</th>
              <th class="p-4 font-semibold w-1/4">アクション</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-apple-border-soft">
            {reports.map((report) => (
              <tr class="hover:bg-gray-50/50 transition-colors">
                <td class="p-4 text-apple-secondary whitespace-nowrap">
                  {new Date(report.createdAt).toLocaleDateString('ja-JP', { month: 'numeric', day: 'numeric', weekday: 'short' })}
                </td>
                <td class="p-4">
                  <div class="font-semibold text-apple-ink">{report.userName}</div>
                  <div class="text-xs text-apple-secondary mt-0.5">{report.userId}</div>
                </td>
                <td class="p-4">
                  <div class="inline-flex flex-col gap-1">
                    <span class="inline-flex items-center px-2.5 py-1 rounded-md text-xs font-medium bg-apple-gray text-apple-ink border border-apple-border-soft w-fit">
                      {report.taskType}
                    </span>
                    <span class="text-xs font-semibold text-apple-secondary ml-1">
                      {report.startTime} - {report.endTime}
                    </span>
                  </div>
                </td>
                <td class="p-4 text-center text-xl">
                  {report.healthStatus === 3 ? '😄' : report.healthStatus === 2 ? '😐' : '😷'}
                </td>
                <td class="p-4 text-apple-ink break-words text-xs">
                  {report.comment || <span class="text-apple-border-soft">-</span>}
                </td>
                <td class="p-4">
                  <a href={`/staff/users/${report.userId}`} class="inline-block bg-white text-apple-blue border border-apple-border-soft px-3 py-1.5 rounded-lg text-xs font-semibold hover:bg-apple-gray transition-colors Edit Goal Button (目標編集)">
                    目標設定
                  </a>
                </td>
              </tr>
            ))}

            {reports.length === 0 && (
              <tr>
                <td colspan="6" class="p-12 text-center text-apple-secondary">
                  日報データがありません。
                </td>
              </tr>
            )}
          </tbody>
        </table>
      </div>
    </div>
  </div>
</Layout>
