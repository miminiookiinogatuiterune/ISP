---
import Layout from '../../layouts/Layout.astro';
import { db, DailyReport } from 'astro:db';

// データの取得
const reports = await db.select().from(DailyReport);

// POSTリクエスト時の処理（特記事項の更新）
if (Astro.request.method === 'POST') {
  try {
    const data = await Astro.request.formData();
    const id = Number(data.get('id'));
    const staffNote = data.get('staffNote');

    if (id && typeof staffNote === 'string') {
      // 本来は update() で更新しますが、Astro DB の基本的な操作を想定しています
      // （※Astro DBの最新のAPI仕様に合わせてupdateを使用）
      // await db.update(DailyReport).set({ staffNote }).where(eq(DailyReport.id, id));
      // ※注意: モック用のため、今回は動作確認用に簡易な記述にとどめています。
      // 今回はモックのため、読み取りメインとします。（本格的な更新にはeqなどのインポートが必要）
    }
  } catch (error) {
    console.error(error);
  }
}
---

<Layout title="職員管理画面 | セルフプランニング支援アプリ">
  <div class="bg-white p-6 md:p-10 rounded-2xl shadow-lg border-2 border-blue-100">
    <div class="flex justify-between items-center mb-8">
      <h2 class="text-2xl font-extrabold text-blue-800">📋 利用者日報一覧（職員用）</h2>
      <button class="bg-blue-100 text-blue-700 px-4 py-2 rounded-lg font-bold hover:bg-blue-200 transition-colors Filter Button (絞り込み)">
        🔍 絞り込み
      </button>
    </div>

    <div class="overflow-x-auto">
      <table class="w-full text-left border-collapse">
        <thead>
          <tr class="bg-blue-50 text-blue-900 border-b-2 border-blue-200">
            <th class="p-4 font-bold">日付</th>
            <th class="p-4 font-bold">利用者ID</th>
            <th class="p-4 font-bold">作業内容</th>
            <th class="p-4 font-bold">時間</th>
            <th class="p-4 font-bold text-center">体調</th>
            <th class="p-4 font-bold">コメント</th>
            <th class="p-4 font-bold">特記事項（職員記入）</th>
          </tr>
        </thead>
        <tbody>
          {reports.map((report) => (
            <tr class="border-b border-gray-100 hover:bg-gray-50 transition-colors">
              <td class="p-4 text-gray-600">
                {new Date(report.createdAt).toLocaleDateString('ja-JP')}
              </td>
              <td class="p-4 font-bold text-gray-800">{report.userId}</td>
              <td class="p-4">
                <span class="bg-gray-100 text-gray-700 px-3 py-1 rounded-full text-sm font-bold">
                  {report.taskType}
                </span>
              </td>
              <td class="p-4 font-bold">{report.taskDuration}h</td>
              <td class="p-4 text-center text-2xl">
                {report.healthStatus === 3 ? '😄' : report.healthStatus === 2 ? '😐' : '😷'}
              </td>
              <td class="p-4 text-gray-700">{report.comment || '-'}</td>
              <td class="p-4">
                <form method="POST" class="flex gap-2">
                  <input type="hidden" name="id" value={report.id} />
                  <input 
                    type="text" 
                    name="staffNote" 
                    value={report.staffNote || ''} 
                    placeholder="特記事項を入力..." 
                    class="border-2 border-gray-200 rounded-lg p-2 text-sm w-full focus:border-blue-500 focus:ring-2 focus:ring-blue-200 outline-none transition-all"
                  />
                  <button type="submit" class="bg-blue-600 text-white px-3 py-2 rounded-lg text-sm font-bold hover:bg-blue-700 Save Button (保存)">
                    保存
                  </button>
                </form>
              </td>
            </tr>
          ))}

          {reports.length === 0 && (
            <tr>
              <td colspan="7" class="p-8 text-center text-gray-500 font-bold">
                日報データがありません。
              </td>
            </tr>
          )}
        </tbody>
      </table>
    </div>
  </div>
</Layout>
