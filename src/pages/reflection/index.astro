---
import Layout from '../../layouts/Layout.astro';
import { db, Reflection, User, eq } from 'astro:db';

let message = "";
let currentUser = null;
let longTermGoal = "";
let shortTermGoals: string[] = [];

// 先月を計算（例: "2026-03"）
const today = new Date();
const lastMonthDate = new Date(today.getFullYear(), today.getMonth() - 1, 1);
const lastMonthStr = `${lastMonthDate.getFullYear()}-${String(lastMonthDate.getMonth() + 1).padStart(2, '0')}`;
const lastMonthDisplay = `${lastMonthDate.getFullYear()}年${lastMonthDate.getMonth() + 1}月`;

// GETリクエスト時（URLパラメータからuserIdを取得し、目標を表示する）
const urlUserId = Astro.url.searchParams.get('userId');
if (urlUserId) {
  const users = await db.select().from(User).where(eq(User.id, urlUserId));
  if (users.length > 0) {
    currentUser = users[0];
    longTermGoal = currentUser.longTermGoal || "";
    if (currentUser.shortTermGoals) {
      shortTermGoals = currentUser.shortTermGoals.split('\n').map((g: string) => g.trim()).filter((g: string) => g.length > 0);
    }
  }
}

if (Astro.request.method === 'POST') {
  try {
    const data = await Astro.request.formData();
    const userId = data.get('userId');
    const changeRequest = data.get('changeRequest') === 'on';

    // 動的に生成される評価データを収集
    const evaluations = [];
    for (const [key, value] of data.entries()) {
      if (key.startsWith('eval_')) {
        const parts = key.split('_'); // eval_long_0, eval_short_0, eval_short_1
        const type = parts[1];
        const index = parts[2];
        const textKey = `text_${type}_${index}`;
        const text = data.get(textKey);
        if (text) {
          evaluations.push({
            type,
            text,
            score: Number(value)
          });
        }
      }
    }

    if (typeof userId === 'string') {
      await db.insert(Reflection).values({
        userId,
        targetMonth: lastMonthStr,
        evaluations: JSON.stringify(evaluations),
        changeRequest
      });
      message = "振り返りを記録しました！日々の記録画面に戻ります。";
    }
  } catch (error) {
    message = "エラーが発生しました。";
    console.error(error);
  }
}
---

<Layout title="先月の振り返り | セルフプランニング支援アプリ">
  <div class="max-w-2xl mx-auto space-y-10">
    
    <div class="text-center mb-6">
      <h2 class="text-3xl font-semibold text-apple-ink tracking-tight mb-2">先月の振り返り</h2>
      <p class="text-apple-secondary text-lg">{lastMonthDisplay}の活動データ</p>
    </div>

    {/* 活動データパネル */}
    <div class="grid grid-cols-2 gap-4">
      <div class="bg-white p-8 rounded-[24px] shadow-[0_4px_24px_rgba(0,0,0,0.04)] border border-apple-border-soft text-center flex flex-col justify-center">
        <div class="text-apple-secondary font-medium text-sm mb-2">出勤日数</div>
        <div class="text-5xl font-semibold text-apple-ink tracking-tight">18<span class="text-xl text-apple-secondary ml-1">日</span></div>
      </div>
      <div class="bg-white p-8 rounded-[24px] shadow-[0_4px_24px_rgba(0,0,0,0.04)] border border-apple-border-soft text-center flex flex-col justify-center">
        <div class="text-apple-secondary font-medium text-sm mb-2">作業時間合計</div>
        <div class="text-5xl font-semibold text-apple-ink tracking-tight">45<span class="text-xl text-apple-secondary ml-1">h</span></div>
      </div>
    </div>
    <p class="text-apple-secondary text-xs mt-2 text-center">※モックのため固定データを表示しています</p>

    {/* 入力フォームパネル */}
    <div class="bg-white p-8 md:p-12 rounded-[24px] shadow-[0_4px_24px_rgba(0,0,0,0.04)] border border-apple-border-soft">
      {message && (
        <div class="mb-8 p-4 bg-gray-50 text-apple-ink font-medium rounded-xl border border-apple-border-soft text-center">
          {message}
        </div>
      )}

      {!message && (
        <form method="POST" class="space-y-10">
          {currentUser ? (
            <input type="hidden" name="userId" value={currentUser.id} />
          ) : (
            <div>
              <label for="userId" class="block text-sm font-semibold text-apple-secondary mb-2">あなたのID</label>
              <div class="flex gap-2">
                <input 
                  type="text" 
                  id="userId" 
                  name="userId" 
                  required
                  placeholder="user001"
                  class="flex-1 p-4 bg-apple-gray border border-apple-border-soft rounded-xl focus:border-apple-border-strong focus:bg-white focus:outline-none transition-colors text-apple-ink font-medium"
                >
                <button type="button" onclick={`window.location.href='?userId='+document.getElementById('userId').value`} class="bg-apple-ink text-white px-6 rounded-xl font-semibold text-sm hover:bg-black Load Goals Button (目標読み込み)">
                  目標を読み込む
                </button>
              </div>
            </div>
          )}

          {currentUser && (
            <div class="space-y-8">
              <div class="pb-4 border-b border-apple-border-soft">
                <h3 class="text-lg font-semibold text-apple-ink mb-1">こんにちは、{currentUser.name} さん</h3>
                <p class="text-sm text-apple-secondary">今月の目標について、それぞれ5段階で評価してください。</p>
              </div>

              {/* 長期目標の評価 */}
              {longTermGoal && (
                <div class="space-y-3">
                  <div class="bg-apple-gray p-4 rounded-xl border border-apple-border-soft">
                    <span class="text-xs font-bold text-apple-blue mb-1 block">長期目標</span>
                    <p class="font-medium text-apple-ink">{longTermGoal}</p>
                    <input type="hidden" name="text_long_0" value={longTermGoal} />
                  </div>
                  <div class="flex justify-between gap-2 px-2">
                    {[1, 2, 3, 4, 5].map((score) => (
                      <label class="flex-1 cursor-pointer">
                        <input type="radio" name="eval_long_0" value={score} class="peer sr-only" required>
                        <div class="text-center py-3 bg-apple-gray text-apple-ink rounded-lg border border-transparent peer-checked:bg-apple-blue peer-checked:text-white font-semibold transition-all hover:bg-gray-200 peer-checked:hover:bg-apple-blue">
                          {score}
                        </div>
                      </label>
                    ))}
                  </div>
                </div>
              )}

              {/* 短期目標の評価 */}
              {shortTermGoals.map((goal, index) => (
                <div class="space-y-3">
                  <div class="bg-apple-gray p-4 rounded-xl border border-apple-border-soft">
                    <span class="text-xs font-bold text-apple-secondary mb-1 block">短期目標 {index + 1}</span>
                    <p class="font-medium text-apple-ink">{goal}</p>
                    <input type="hidden" name={`text_short_${index}`} value={goal} />
                  </div>
                  <div class="flex justify-between gap-2 px-2">
                    {[1, 2, 3, 4, 5].map((score) => (
                      <label class="flex-1 cursor-pointer">
                        <input type="radio" name={`eval_short_${index}`} value={score} class="peer sr-only" required>
                        <div class="text-center py-3 bg-apple-gray text-apple-ink rounded-lg border border-transparent peer-checked:bg-apple-ink peer-checked:text-white font-semibold transition-all hover:bg-gray-200 peer-checked:hover:bg-apple-ink">
                          {score}
                        </div>
                      </label>
                    ))}
                  </div>
                </div>
              ))}
              
              <div class="flex justify-between text-xs text-apple-secondary font-medium px-4">
                <span>まったくできなかった (1)</span>
                <span>よくできた (5)</span>
              </div>
            </div>
          )}

          <div class="p-6 bg-apple-gray rounded-[20px] border border-apple-border-soft">
            <label class="flex items-start gap-4 cursor-pointer group">
              <div class="relative flex items-center justify-center mt-0.5">
                <input type="checkbox" name="changeRequest" class="peer appearance-none w-6 h-6 border-2 border-apple-border-strong rounded-[6px] checked:bg-apple-blue checked:border-apple-blue transition-colors cursor-pointer">
                <svg class="absolute w-4 h-4 text-white opacity-0 peer-checked:opacity-100 pointer-events-none" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
              </div>
              <div class="flex-1">
                <span class="text-base font-semibold text-apple-ink block mb-1">来月から作業内容や時間を変更したいですか？</span>
                <span class="text-sm text-apple-secondary">チェックを入れると、職員から相談のお声がけをします。</span>
              </div>
            </label>
          </div>

          <div class="pt-4">
            <button 
              type="submit" 
              class="w-full text-lg font-semibold text-white bg-apple-blue py-4 rounded-full shadow-[0_4px_14px_rgba(0,113,227,0.3)] hover:bg-apple-blue-hover active:scale-[0.98] transition-all Submit Button (送信)"
            >
              振り返りを送信する
            </button>
          </div>
        </form>
      )}
    </div>
  </div>
</Layout>
